# Qplus Surgery 오프라인 운영 환경변수 템플릿
# 이 파일을 `.env`로 복사한 뒤 실제 운영값으로 수정하세요.

# 1. 저장소
# local: `.local_data/storage`에 파일로 저장
# gcs: Google Cloud Storage 사용
STORAGE_BACKEND="local"
OFFLINE_MODE="true"
LOCAL_STORAGE_ROOT=".local_data/storage"
GCS_BUCKET_NAME="lgbtqplus-surgery"

# 2. 보안 및 인증
# 내부망 오프라인 운영은 Cloudflare Access 없이 계정 로그인 fallback을 사용합니다.
REQUIRE_CLOUDFLARE_ACCESS="false"
ALLOW_ACCOUNT_ID_FALLBACK="true"
ALLOW_GOOGLE_AUTH_FALLBACK="false"
ALLOW_PUBLIC_REGISTRATION="false"

# 3. 초기 관리자 계정
# 운영 전 반드시 변경하세요.
JISONG_OWNER_EMAIL="admin@example.com"
JISONG_ACCOUNT_LOGIN_ID="admin@example.com"
ADMIN_PASSWORD="change-this-admin-password"

# 4. Passkey 설정
# 내부망 접속 주소가 http://192.168.0.35:8080 이라면 아래처럼 맞춥니다.
PASSKEY_RP_ID="192.168.0.35"
PASSKEY_ORIGIN="http://192.168.0.35:8080"
PASSKEY_RP_NAME="Qplus Surgery"

# 5. Google Calendar
# 오프라인 운영 기본값은 비활성화입니다.
GOOGLE_CALENDAR_SYNC_ENABLED="false"
GOOGLE_CALENDAR_ID="primary"
GDRIVE_CLIENT_ID=""
GDRIVE_CLIENT_SECRET=""
GDRIVE_REDIRECT_URI="http://192.168.0.35:8080/api/auth/gdrive/callback"
