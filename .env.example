# LGBTQ+ Surgery API 서버 로컬 실행 환경변수 템플릿 (.env)
# 이 파일을 복사하여 `.env`로 이름을 바꾼 후 실제 값을 입력하여 사용하세요.

# 1. Google Cloud Storage 설정
GCS_BUCKET_NAME="lgbtqplus-surgery"

# 2. 보안 및 인증 Fallback 정책
# 로컬 병원 내부망 접속용으로 uvicorn 단독 구동 시 False 설정
REQUIRE_CLOUDFLARE_ACCESS="false"
ALLOW_ACCOUNT_ID_FALLBACK="true"

# 3. 신규 사용자 공개 회원가입 허용 여부
# False일 경우 /api/auth/account/register 호출 시 403 Forbidden 반환
ALLOW_PUBLIC_REGISTRATION="false"

# 4. 초기 관리자 계정 정보
JISONG_ACCOUNT_LOGIN_ID="admin@example.com"
ADMIN_PASSWORD="super-secret-admin-password"

# 5. 패스크(Passkey) 설정 (병원 내부망 맥미니 IP 기입)
PASSKEY_RP_ID="192.168.0.35"
PASSKEY_ORIGIN="http://192.168.0.35:8080"
PASSKEY_RP_NAME="Qplus Surgery"

# 6. 구글 캘린더 연동 설정
GOOGLE_CALENDAR_ID="primary"
GDRIVE_CLIENT_ID=""
GDRIVE_CLIENT_SECRET=""
GDRIVE_REDIRECT_URI="http://192.168.0.35:8080/api/auth/gdrive/callback"
