JISONG_CLOUD_PORT=8501

# Streamlit app auth. Keep this different from Cloudflare Access credentials.
ADMIN_PASSWORD=change-me

# Existing GCS storage.
GCS_BUCKET_NAME=your-gcs-bucket-name
GCP_SERVICE_ACCOUNT_FILE=/Users/jsbang/jisong-data/secrets/gcp-service-account.json

# Mac mini storage. local_mirror reads local disk first and mirrors writes to GCS.
STORAGE_BACKEND=local_mirror
LOCAL_STORAGE_HOST_PATH=/Users/jsbang/jisong-data/storage
LOCAL_STORAGE_SYNC_TO_GCS=true
LOCAL_STORAGE_PULL_FROM_GCS=true

# Gemini remains available for Cloud Run parity.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Mac mini AI mode. Set AI_PROVIDER=ollama to use local Ollama by default.
AI_PROVIDER=gemini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_MODEL_OPTIONS=gemma4:e4b,qwen3.5:9b
AI_FALLBACK_PROVIDER=gemini

# Use these only when Cloud Run calls Ollama through a Cloudflare Access service token.
OLLAMA_CF_ACCESS_CLIENT_ID=
OLLAMA_CF_ACCESS_CLIENT_SECRET=

# Cloudflare Tunnel token for mac.jisong.dev.
CLOUDFLARED_TOKEN=replace-with-cloudflare-tunnel-token
